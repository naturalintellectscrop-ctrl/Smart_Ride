{
  "expo": {
    "name": "Smart Ride",
    "slug": "smart-ride-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "../assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#00FF88"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ug.smartride.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "../assets/adaptive-icon.png",
        "backgroundColor": "#00FF88"
      },
      "package": "ug.smartride.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "96fc7339-6554-4017-a800-64119cbbf150"
      }
    }
  }
}
