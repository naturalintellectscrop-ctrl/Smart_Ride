{
  "name": "Smart Ride",
  "short_name": "Smart Ride",
  "description": "Multi-Service Mobility Platform for Uganda - Ride, Food Delivery, Shopping & More",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0D0D12",
  "theme_color": "#00FF88",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["transportation", "food", "shopping", "delivery"],
  "icons": [
    {
      "src": "/smartride-logo.jpeg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "purpose": "any"
    },
    {
      "src": "/favicon.jpg",
      "sizes": "any",
      "type": "image/jpeg",
      "purpose": "any"
    }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Book a Ride",
      "short_name": "Ride",
      "description": "Book a Smart Boda or Smart Car ride",
      "url": "/?action=ride"
    },
    {
      "name": "Order Food",
      "short_name": "Food",
      "description": "Order food delivery from restaurants",
      "url": "/?action=food"
    },
    {
      "name": "Shopping",
      "short_name": "Shop",
      "description": "Order groceries and shopping delivery",
      "url": "/?action=shopping"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+smartride",
      "url": "/handle?data=%s"
    }
  ]
}
