# Smart Ride Mobile App Environment Variables
# Copy this file to .env and fill in your values
# 
# Get Firebase config from: Firebase Console > Project Settings > Your Apps

# ===========================================
# API Configuration
# ===========================================
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# ===========================================
# Mapbox Configuration
# Get from: https://account.mapbox.com/access-tokens/
# ===========================================
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# ===========================================
# Firebase Configuration
# Get from: Firebase Console > Project Settings > General > Your Apps > Web App
# ===========================================
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase VAPID Keys for Push Notifications
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
EXPO_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key_here
EXPO_PUBLIC_FIREBASE_VAPID_KEY_SECONDARY=your_secondary_vapid_key_here
