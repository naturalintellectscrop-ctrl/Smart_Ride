generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  phone                    String?                   @unique
  passwordHash             String?
  name                     String
  role                     UserRole                  @default(CLIENT)
  status                   UserStatus                @default(ACTIVE)
  authProvider             String?
  avatarUrl                String?
  refreshToken             String?
  refreshTokenExpiresAt    DateTime?
  lastLoginAt              DateTime?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  auditLogs                AuditLog[]                @relation("UserAuditLogs")
  cashCollections          CashCollection[]
  conversationParticipants ConversationParticipant[]
  disputes                 Dispute[]
  notificationLogs         NotificationLog[]
  notifications            Notification[]
  notificationPreference   NotificationPreference?
  orders                   Order[]
  payments                 Payment[]
  ratingsGiven             Rating[]                  @relation("RatingFromUser")
  ratingsReceived          Rating[]                  @relation("RatingToUser")
  rider                    Rider?
  sessions                 Session[]
  sosAlerts                SOSAlert[]                @relation("UserSOSAlerts")
  tasks                    Task[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([status])
}

// ============================================
// SESSION MODEL - Production Auth System
// Supports multi-device sessions with revocation
// ============================================
model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String // Hashed refresh token (NEVER store raw token)
  deviceId         String? // Unique device identifier
  deviceName       String? // e.g., "iPhone 14 Pro", "Samsung Galaxy S23"
  deviceType       String? // "ios", "android", "web"
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastAccessedAt   DateTime  @default(now())
  revoked          Boolean   @default(false)
  revokedAt        DateTime?
  revokedReason    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revoked])
}

// ============================================
// OTP MODEL - Phone Authentication
// ============================================
model OTP {
  id         String    @id @default(cuid())
  phone      String
  otpHash    String // Hashed OTP (NEVER store raw OTP)
  purpose    String // "login", "register", "reset_password"
  attempts   Int       @default(0)
  verified   Boolean   @default(false)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  verifiedAt DateTime?

  @@index([phone])
  @@index([expiresAt])
}

// ============================================
// PASSWORD RESET TOKEN MODEL
// Supports forgot password flow for admin users
// ============================================
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model Rider {
  id                 String           @id @default(cuid())
  userId             String           @unique
  fullName           String
  physicalAddress    String
  phone              String           @unique
  email              String?
  facePhotoUrl       String?
  nationalIdFrontUrl String?
  nationalIdBackUrl  String?
  driverLicenseUrl   String?
  riderRole          RiderRole
  vehicleType        VehicleType?
  status             RiderStatus      @default(PENDING_APPROVAL)
  verificationNotes  String?
  verifiedAt         DateTime?
  verifiedBy         String?
  hasReflectorVest   Boolean          @default(false)
  hasHelmet          Boolean          @default(false)
  hasInsulatedBox    Boolean          @default(false)
  isOnline           Boolean          @default(false)
  currentLatitude    Float?
  currentLongitude   Float?
  lastLocationUpdate DateTime?
  rating             Float            @default(5.0)
  totalTrips         Int              @default(0)
  completedTrips     Int              @default(0)
  cancelledTrips     Int              @default(0)
  lastHeartbeatAt    DateTime?
  connectionStatus   ConnectionStatus @default(ACTIVE)
  lastKnownLatitude  Float?
  lastKnownLongitude Float?
  lastKnownSpeed     Float?
  lastKnownBattery   Int?
  lastKnownHeading   Float?
  currentTaskId      String?
  totalEarnings      Float            @default(0)
  walletBalance      Float            @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  auditLogs          AuditLog[]       @relation("RiderAuditLogs")
  cashCollections    CashCollection[]
  dispatchMatches    DispatchMatch[]
  heartbeatLogs      HeartbeatLog[]
  transactions       Transaction[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  riderPayouts       RiderPayout[]
  sosAlerts          SOSAlert[]       @relation("RiderSOSAlerts")
  tasks              Task[]
  vehicle            Vehicle?

  @@index([riderRole])
  @@index([status])
  @@index([isOnline])
  @@index([currentLatitude, currentLongitude])
}

model Vehicle {
  id                 String   @id @default(cuid())
  riderId            String   @unique
  make               String
  model              String
  year               Int?
  color              String
  plateNumber        String   @unique
  registrationDocUrl String?
  insuranceDocUrl    String?
  inspectionDocUrl   String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  rider              Rider    @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@index([plateNumber])
}

model Merchant {
  id                 String         @id @default(cuid())
  name               String
  type               MerchantType
  description        String?
  phone              String
  email              String?
  address            String
  latitude           Float?
  longitude          Float?
  city               String?
  isOpen             Boolean        @default(false)
  openingTime        String?
  closingTime        String?
  averagePrepTime    Int            @default(15)
  commissionRate     Float          @default(0.15)
  bankAccountName    String?
  bankAccountNumber  String?
  bankName           String?
  status             MerchantStatus @default(PENDING_APPROVAL)
  verifiedAt         DateTime?
  verifiedBy         String?
  logoUrl            String?
  coverImageUrl      String?
  businessLicenseUrl String?
  totalOrders        Int            @default(0)
  rating             Float          @default(5.0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  auditLogs          AuditLog[]     @relation("MerchantAuditLogs")
  kots               KOT[]
  menuItems          MenuItem[]
  orders             Order[]
  pharmacy           Pharmacy?

  @@index([type])
  @@index([status])
  @@index([isOpen])
  @@index([latitude, longitude])
}

model MenuItem {
  id              String           @id @default(cuid())
  merchantId      String
  name            String
  description     String?
  price           Float
  imageUrl        String?
  category        String?
  isAvailable     Boolean          @default(true)
  stockQuantity   Int?
  preparationTime Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  variants        ProductVariant[]
  reservations    InventoryReservation[]

  @@index([merchantId])
  @@index([category])
}

model Order {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  clientId             String
  merchantId           String?
  orderType            OrderType
  subtotal             Float
  deliveryFee          Float
  serviceFee           Float?
  discount             Float?
  totalAmount          Float
  paymentMethod        PaymentMethod
  paymentStatus        PaymentStatus @default(PENDING)
  paymentReference     String?
  status               OrderStatus   @default(ORDER_CREATED)
  deliveryAddress      String
  deliveryLatitude     Float?
  deliveryLongitude    Float?
  deliveryInstructions String?
  recipientName        String?
  recipientPhone       String?
  confirmedAt          DateTime?
  acceptedAt           DateTime?
  preparingAt          DateTime?
  readyAt              DateTime?
  pickedUpAt           DateTime?
  deliveredAt          DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  auditLogs            AuditLog[]    @relation("OrderAuditLogs")
  kot                  KOT?
  client               User          @relation(fields: [clientId], references: [id])
  merchant             Merchant?     @relation(fields: [merchantId], references: [id])
  items                OrderItem[]
  task                 Task?

  @@index([clientId])
  @@index([merchantId])
  @@index([status])
  @@index([orderType])
  @@index([createdAt])
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  menuItemId          String?
  itemName            String
  itemDescription     String?
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  specialInstructions String?
  createdAt           DateTime  @default(now())
  menuItem            MenuItem? @relation(fields: [menuItemId], references: [id])
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model KOT {
  id                  String    @id @default(cuid())
  kotNumber           String    @unique
  orderId             String    @unique
  merchantId          String
  status              KOTStatus @default(GENERATED)
  items               String
  specialInstructions String?
  estimatedPrepTime   Int?
  printedAt           DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  merchant            Merchant  @relation(fields: [merchantId], references: [id])
  order               Order     @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([status])
}

model Task {
  id                  String                @id @default(cuid())
  taskNumber          String                @unique
  taskType            TaskType
  clientId            String
  riderId             String?
  orderId             String?               @unique
  status              TaskStatus            @default(CREATED)
  pickupAddress       String
  pickupLatitude      Float?
  pickupLongitude     Float?
  pickupContactName   String?
  pickupContactPhone  String?
  dropoffAddress      String
  dropoffLatitude     Float?
  dropoffLongitude    Float?
  dropoffContactName  String?
  dropoffContactPhone String?
  distanceKm          Float?
  estimatedDuration   Int?
  actualDuration      Int?
  baseFare            Float
  distanceFare        Float?
  timeFare            Float?
  deliveryFee         Float?
  serviceFee          Float?
  discount            Float?
  totalAmount         Float
  platformCommission  Float?
  riderEarnings       Float?
  paymentMethod       PaymentMethod
  paymentStatus       PaymentStatus         @default(PENDING)
  passengerCount      Int?
  passengerNames      String?
  itemDescription     String?
  itemWeight          Float?
  itemValue           Float?
  cancellationReason  String?
  cancellationCode    String?
  cancelledBy         String?
  matchingStartedAt   DateTime?
  assignedAt          DateTime?
  acceptedAt          DateTime?
  arrivedAtPickupAt   DateTime?
  pickedUpAt          DateTime?
  inProgressAt        DateTime?
  deliveringAt        DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  lastHeartbeatAt     DateTime?
  lastKnownLatitude   Float?
  lastKnownLongitude  Float?
  connectionStatus    ConnectionStatus?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  healthOrderId       String?               @unique
  auditLogs           AuditLog[]            @relation("TaskAuditLogs")
  conversation        Conversation?
  dispatchMatches     DispatchMatch[]
  dispute             Dispute?
  heartbeatLogs       HeartbeatLog[]
  payment             Payment?
  rating              Rating?
  sosAlerts           SOSAlert[]            @relation("TaskSOSAlerts")
  stateTransitions    TaskStateTransition[]
  transactions        Transaction[]
  client              User                  @relation(fields: [clientId], references: [id])
  healthOrder         HealthOrder?          @relation(fields: [healthOrderId], references: [id])
  order               Order?                @relation(fields: [orderId], references: [id])
  rider               Rider?                @relation(fields: [riderId], references: [id])

  @@index([taskType])
  @@index([status])
  @@index([clientId])
  @@index([riderId])
  @@index([createdAt])
  @@index([pickupLatitude, pickupLongitude])
  @@index([dropoffLatitude, dropoffLongitude])
}

model Payment {
  id                String        @id @default(cuid())
  paymentReference  String        @unique
  taskId            String?       @unique
  userId            String
  amount            Float
  currency          String        @default("UGX")
  paymentMethod     PaymentMethod
  status            PaymentStatus @default(PENDING)
  transactionId     String?
  providerResponse  String?
  failureReason     String?
  phoneNumber       String?
  momoTransactionId String?
  cardLastFour      String?
  cardBrand         String?
  processedAt       DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  task              Task?         @relation(fields: [taskId], references: [id])
  user              User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([paymentMethod])
  @@index([createdAt])
}

model RiderPayout {
  id            String       @id @default(cuid())
  riderId       String
  amount        Float
  currency      String       @default("UGX")
  status        PayoutStatus @default(PENDING)
  periodStart   DateTime
  periodEnd     DateTime
  taskCount     Int
  transactionId String?
  paymentMethod String?
  phoneNumber   String?
  processedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  rider         Rider        @relation(fields: [riderId], references: [id])

  @@index([riderId])
  @@index([status])
}

model CashCollection {
  id             String           @id @default(cuid())
  riderId        String
  userId         String?
  taskId         String?
  amount         Float
  currency       String           @default("UGX")
  collectionType CollectionType
  status         CollectionStatus @default(PENDING)
  collectedAt    DateTime?
  depositedAt    DateTime?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  rider          Rider            @relation(fields: [riderId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])

  @@index([riderId])
  @@index([status])
  @@index([collectionType])
}

model FinanceLog {
  id                 String          @id @default(cuid())
  transactionType    TransactionType
  referenceId        String
  amount             Float
  currency           String          @default("UGX")
  clientId           String?
  riderId            String?
  merchantId         String?
  platformCommission Float?
  riderEarnings      Float?
  merchantEarnings   Float?
  status             String
  description        String?
  metadata           String?
  createdAt          DateTime        @default(now())

  @@index([transactionType])
  @@index([referenceId])
  @@index([createdAt])
}

model Rating {
  id                    String   @id @default(cuid())
  taskId                String   @unique
  fromUserId            String
  toUserId              String?
  toRiderId             String?
  score                 Int
  comment               String?
  punctualityScore      Int?
  professionalismScore  Int?
  vehicleConditionScore Int?
  createdAt             DateTime @default(now())
  fromUser              User     @relation("RatingFromUser", fields: [fromUserId], references: [id])
  task                  Task     @relation(fields: [taskId], references: [id])
  toUser                User?    @relation("RatingToUser", fields: [toUserId], references: [id])

  @@index([fromUserId])
  @@index([toUserId])
}

model AuditLog {
  id            String       @id @default(cuid())
  actorId       String?
  actorType     ActorType
  userId        String?
  riderId       String?
  merchantId    String?
  action        String
  entityType    String
  entityId      String
  orderId       String?
  taskId        String?
  description   String?
  oldValues     String?
  newValues     String?
  ipAddress     String?
  userAgent     String?
  source        String       @default("SYSTEM") // ADMIN_DASHBOARD | MOBILE_APP | API | SYSTEM
  createdAt     DateTime     @default(now())
  healthOrderId String?
  healthOrder   HealthOrder? @relation("HealthOrderAuditLogs", fields: [healthOrderId], references: [id])
  merchant      Merchant?    @relation("MerchantAuditLogs", fields: [merchantId], references: [id])
  order         Order?       @relation("OrderAuditLogs", fields: [orderId], references: [id])
  rider         Rider?       @relation("RiderAuditLogs", fields: [riderId], references: [id])
  task          Task?        @relation("TaskAuditLogs", fields: [taskId], references: [id])
  user          User?        @relation("UserAuditLogs", fields: [userId], references: [id])

  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@index([source])
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  title         String
  message       String
  type          NotificationType
  referenceId   String?
  referenceType String?
  isRead        Boolean          @default(false)
  readAt        DateTime?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  surgeAlerts          Boolean  @default(true)
  highDemandAlerts     Boolean  @default(true)
  incentiveAlerts      Boolean  @default(true)
  earningsOpportunities Boolean @default(true)
  repositionRequests   Boolean  @default(true)
  surgeWarnings        Boolean  @default(true)
  promoAlerts          Boolean  @default(true)
  discountOffers       Boolean  @default(true)
  taskUpdates          Boolean  @default(true)
  orderUpdates         Boolean  @default(true)
  paymentUpdates       Boolean  @default(true)
  systemUpdates        Boolean  @default(true)
  quietHoursEnabled    Boolean  @default(false)
  quietHoursStart      String   @default("22:00")
  quietHoursEnd        String   @default("07:00")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationBroadcast {
  id               String    @id @default(cuid())
  zoneId           String?
  broadcastType    String
  title            String
  message          String
  targetAudience   String
  referenceId      String?
  referenceType    String?
  metadata         String?
  expiresAt        DateTime?
  status           String    @default("PENDING")
  sentAt           DateTime?
  recipientsCount  Int       @default(0)
  deliveredCount   Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([broadcastType])
  @@index([status])
  @@index([createdAt])
}

model SOSAlert {
  id              String    @id @default(cuid())
  alertNumber     String    @unique
  userId          String?
  riderId         String?
  taskId          String?
  userType        String
  userName        String
  userPhone       String
  riderName       String?
  riderPhone      String?
  vehicleInfo     String?
  taskNumber      String?
  taskType        String?
  latitude        Float
  longitude       Float
  locationAddress String?
  status          SOSStatus @default(ACTIVE)
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?
  actionsTaken    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  rider           Rider?    @relation("RiderSOSAlerts", fields: [riderId], references: [id])
  task            Task?     @relation("TaskSOSAlerts", fields: [taskId], references: [id])
  user            User?     @relation("UserSOSAlerts", fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SLAConfig {
  id          String   @id @default(cuid())
  serviceType String
  state       String
  slaMinutes  Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([serviceType, state])
}

model PricingConfig {
  id                        String   @id @default(cuid())
  serviceType               String   @unique
  baseFare                  Float
  perKmRate                 Float
  perMinuteRate             Float?
  minimumFare               Float
  maximumFare               Float?
  platformCommissionPercent Float?
  serviceFeePercent         Float?
  nightSurchargePercent     Float?
  peakSurchargePercent      Float?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model HeartbeatLog {
  id               String           @id @default(cuid())
  riderId          String
  taskId           String?
  latitude         Float
  longitude        Float
  speed            Float?
  heading          Float?
  accuracy         Float?
  batteryLevel     Int?
  isCharging       Boolean?
  networkType      String?
  connectionStatus ConnectionStatus @default(ACTIVE)
  metadata         String?
  createdAt        DateTime         @default(now())
  rider            Rider            @relation(fields: [riderId], references: [id], onDelete: Cascade)
  task             Task?            @relation(fields: [taskId], references: [id])

  @@index([riderId])
  @@index([taskId])
  @@index([createdAt])
  @@index([connectionStatus])
}

model ConnectionAlert {
  id              String        @id @default(cuid())
  riderId         String
  taskId          String?
  alertType       AlertType
  severity        AlertSeverity
  message         String
  isAcknowledged  Boolean       @default(false)
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  isResolved      Boolean       @default(false)
  resolvedAt      DateTime?
  resolutionNotes String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([riderId])
  @@index([taskId])
  @@index([isAcknowledged])
  @@index([createdAt])
}

model HealthOrder {
  id                     String                  @id @default(cuid())
  orderNumber            String                  @unique
  clientId               String
  providerId             String?
  pharmacyId             String?
  orderType              HealthOrderType
  prescriptionId         String?
  subtotal               Float
  deliveryFee            Float
  serviceFee             Float?
  discount               Float?
  totalAmount            Float
  paymentMethod          PaymentMethod
  paymentStatus          PaymentStatus           @default(PENDING)
  paymentReference       String?
  status                 HealthOrderStatus       @default(ORDER_PLACED)
  deliveryAddress        String
  deliveryLatitude       Float?
  deliveryLongitude      Float?
  deliveryInstructions   String?
  recipientName          String?
  recipientPhone         String?
  isFragile              Boolean                 @default(false)
  isTemperatureSensitive Boolean                 @default(false)
  handlingInstructions   String?
  placedAt               DateTime                @default(now())
  reviewedAt             DateTime?
  verifiedAt             DateTime?
  preparingAt            DateTime?
  readyAt                DateTime?
  pickedUpAt             DateTime?
  deliveredAt            DateTime?
  cancelledAt            DateTime?
  cancellationReason     String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  auditLogs              AuditLog[]              @relation("HealthOrderAuditLogs")
  pharmacy               Pharmacy?               @relation(fields: [pharmacyId], references: [id])
  prescription           Prescription?           @relation(fields: [prescriptionId], references: [id])
  provider               HealthProvider?         @relation(fields: [providerId], references: [id])
  items                  HealthOrderItem[]
  pot                    PharmacyOrderTicket?
  prescriptionAccessLogs PrescriptionAccessLog[]
  task                   Task?

  @@index([clientId])
  @@index([pharmacyId])
  @@index([status])
  @@index([orderType])
  @@index([createdAt])
}

model HealthOrderItem {
  id                  String           @id @default(cuid())
  healthOrderId       String
  medicineCatalogId   String?
  medicineName        String
  medicineDescription String?
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  dosageInstructions  String?
  specialInstructions String?
  createdAt           DateTime         @default(now())
  healthOrder         HealthOrder      @relation(fields: [healthOrderId], references: [id], onDelete: Cascade)
  medicineCatalog     MedicineCatalog? @relation(fields: [medicineCatalogId], references: [id])

  @@index([healthOrderId])
  @@index([medicineCatalogId])
}

model Prescription {
  id                 String                  @id @default(cuid())
  prescriptionNumber String                  @unique
  clientId           String
  imageUrl           String
  imageHash          String?
  doctorName         String?
  doctorLicense      String?
  clinicName         String?
  prescriptionDate   DateTime?
  expiryDate         DateTime?
  status             PrescriptionStatus      @default(PENDING)
  verifiedBy         String?
  verifiedAt         DateTime?
  verificationNotes  String?
  rejectionReason    String?
  medicines          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  healthOrders       HealthOrder[]
  accessLogs         PrescriptionAccessLog[]

  @@index([clientId])
  @@index([status])
}

model HealthProvider {
  id                          String             @id @default(cuid())
  userId                      String?            @unique
  businessName                String
  licenseNumber               String
  licenseDocumentUrl          String?
  licenseExpiryDate           DateTime?
  issuingAuthority            String?
  ownerFullName               String
  ownerPhone                  String
  ownerEmail                  String?
  ownerNIN                    String?
  address                     String
  city                        String?
  district                    String?
  latitude                    Float?
  longitude                   Float?
  serviceRadius               Int                @default(10)
  facilityPhotoUrl            String?
  interiorPhotoUrl            String?
  additionalPhotos            String?
  additionalDocuments         String?
  operatingHours              String?
  is24Hours                   Boolean            @default(false)
  supportsPrescription        Boolean            @default(true)
  supportsOTC                 Boolean            @default(true)
  supportsDelivery            Boolean            @default(true)
  supportsPickup              Boolean            @default(true)
  offersConsultation          Boolean            @default(false)
  emergencyContactName        String?
  emergencyContactPhone       String?
  bankName                    String?
  bankAccountName             String?
  bankAccountNumber           String?
  mobileMoneyNumber           String?
  mobileMoneyProvider         String?
  verifiedAt                  DateTime?
  verifiedBy                  String?
  verificationNotes           String?
  totalOrders                 Int                @default(0)
  rating                      Float              @default(5.0)
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt
  cancelledOrders             Int                @default(0)
  commissionRate              Float              @default(0.10)
  completedOrders             Int                @default(0)
  complianceScore             Int                @default(100)
  flagReason                  String?
  flaggedAt                   DateTime?
  flaggedBy                   String?
  hasComplianceIssues         Boolean            @default(false)
  isFlagged                   Boolean            @default(false)
  isOpenNow                   Boolean            @default(false)
  lastComplianceCheck         DateTime?
  pendingPayout               Float              @default(0)
  rejectionReason             String?
  totalEarnings               Float              @default(0)
  totalPrescriptionsProcessed Int                @default(0)
  totalReviews                Int                @default(0)
  providerType                HealthProviderType
  verificationStatus          VerificationStatus @default(PENDING)
  healthOrders                HealthOrder[]
  medicineCatalog             MedicineCatalog[]
  documents                   ProviderDocument[]
  providerOrders              ProviderOrder[]

  @@index([providerType])
  @@index([verificationStatus])
  @@index([city])
  @@index([district])
  @@index([isOpenNow])
  @@index([latitude, longitude])
}

model ProviderDocument {
  id                String         @id @default(cuid())
  providerId        String
  documentType      String
  documentName      String
  documentUrl       String
  documentSize      Int?
  isVerified        Boolean        @default(false)
  verifiedBy        String?
  verifiedAt        DateTime?
  verificationNotes String?
  uploadedAt        DateTime       @default(now())
  provider          HealthProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([documentType])
}

model ProviderOrder {
  id                         String              @id @default(cuid())
  orderNumber                String              @unique
  providerId                 String
  customerId                 String
  customerName               String?
  customerPhone              String?
  orderType                  HealthOrderType
  prescriptionId             String?
  prescriptionVerified       Boolean             @default(false)
  prescriptionVerifiedBy     String?
  prescriptionVerifiedAt     DateTime?
  prescriptionRejectedReason String?
  items                      String
  subtotal                   Float
  deliveryFee                Float
  serviceFee                 Float               @default(0)
  discount                   Float               @default(0)
  totalAmount                Float
  providerEarnings           Float
  status                     ProviderOrderStatus @default(ORDER_RECEIVED)
  receivedAt                 DateTime            @default(now())
  acceptedAt                 DateTime?
  preparingAt                DateTime?
  readyAt                    DateTime?
  pickedUpAt                 DateTime?
  deliveredAt                DateTime?
  cancelledAt                DateTime?
  cancellationReason         String?
  deliveryAddress            String
  deliveryLatitude           Float?
  deliveryLongitude          Float?
  deliveryInstructions       String?
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  provider                   HealthProvider      @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([status])
  @@index([customerId])
}

model Pharmacy {
  id                   String            @id @default(cuid())
  merchantId           String            @unique
  pharmacyLicense      String
  pharmacyLicenseUrl   String?
  pharmacistInCharge   String
  pharmacistLicense    String
  operatingHours       String?
  supportsPrescription Boolean           @default(true)
  supportsOTC          Boolean           @default(true)
  deliveryRadius       Float             @default(10.0)
  status               PharmacyStatus    @default(PENDING_APPROVAL)
  isOpen               Boolean           @default(false)
  totalOrders          Int               @default(0)
  rating               Float             @default(5.0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  healthOrders         HealthOrder[]
  medicineCatalog      MedicineCatalog[]
  merchant             Merchant          @relation(fields: [merchantId], references: [id])

  @@index([status])
  @@index([isOpen])
}

model MedicineCatalog {
  id                   String            @id @default(cuid())
  providerId           String?
  pharmacyId           String?
  name                 String
  genericName          String?
  description          String?
  category             MedicineCategory
  manufacturer         String?
  price                Float
  isAvailable          Boolean           @default(true)
  stockQuantity        Int?
  requiresPrescription Boolean           @default(false)
  storageCondition     String?
  handlingInstructions String?
  imageUrl             String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  healthOrderItems     HealthOrderItem[]
  pharmacy             Pharmacy?         @relation(fields: [pharmacyId], references: [id])
  provider             HealthProvider?   @relation(fields: [providerId], references: [id])

  @@index([providerId])
  @@index([pharmacyId])
  @@index([category])
  @@index([isAvailable])
}

model PharmacyOrderTicket {
  id                      String      @id @default(cuid())
  potNumber               String      @unique
  healthOrderId           String      @unique
  items                   String
  prescriptionRef         String?
  preparationNotes        String?
  status                  POTStatus   @default(GENERATED)
  hasFragileItems         Boolean     @default(false)
  hasTemperatureSensitive Boolean     @default(false)
  estimatedPrepTime       Int         @default(15)
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  healthOrder             HealthOrder @relation(fields: [healthOrderId], references: [id])

  @@index([status])
}

model PrescriptionAccessLog {
  id             String       @id @default(cuid())
  prescriptionId String
  accessedBy     String
  accessedByType String
  healthOrderId  String?
  action         String
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  healthOrder    HealthOrder? @relation(fields: [healthOrderId], references: [id])
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
  @@index([accessedBy])
  @@index([createdAt])
}

model FraudAlert {
  id              String           @id @default(cuid())
  userId          String?
  riderId         String?
  taskId          String?
  orderId         String?
  alertType       FraudAlertType
  riskScore       Int
  severity        AlertSeverity
  description     String
  indicators      String?
  status          FraudAlertStatus @default(OPEN)
  reviewedBy      String?
  reviewedAt      DateTime?
  resolution      String?
  resolutionNotes String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([riderId])
  @@index([alertType])
  @@index([status])
  @@index([createdAt])
}

model ApiRateLimit {
  id           String   @id @default(cuid())
  identifier   String   @unique
  endpoint     String
  requestCount Int      @default(1)
  windowStart  DateTime @default(now())

  @@index([identifier])
  @@index([windowStart])
}

model Conversation {
  id           String                    @id @default(cuid())
  type         ConversationType          @default(DIRECT)
  taskId       String?                   @unique
  isActive     Boolean                   @default(true)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  task         Task?                     @relation(fields: [taskId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]

  @@index([taskId])
  @@index([isActive])
  @@index([updatedAt])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType  @default(TEXT)
  mediaUrl       String?
  mediaType      String?
  mediaSize      Int?
  isRead         Boolean      @default(false)
  readAt         DateTime?
  metadata       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([isRead])
}

model Document {
  id                String         @id @default(cuid())
  riderId           String?
  documentType      DocumentType
  fileName          String
  fileUrl           String
  fileSize          Int?
  mimeType          String?
  status            DocumentStatus @default(PENDING)
  verifiedAt        DateTime?
  verifiedBy        String?
  rejectionReason   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  merchantId        String?
  description       String?
  providerId        String?
  verificationNotes String?

  @@index([riderId])
  @@index([merchantId])
  @@index([providerId])
  @@index([documentType])
  @@index([status])
}

// ============================================
// RIDER CAPABILITY MODEL
// Defines which task types each rider role can handle
// ============================================
model RiderCapability {
  id                   String    @id @default(cuid())
  riderRole            RiderRole
  taskType             TaskType
  isAllowed            Boolean   @default(true)
  requiresVehicle      Boolean   @default(false)
  requiresInsulatedBox Boolean   @default(false)
  maxDistance          Float? // Maximum delivery distance in km
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([riderRole, taskType])
  @@index([riderRole])
  @@index([taskType])
}

// ============================================
// TASK STATE TRANSITION MODEL
// Audit trail for all task state changes
// ============================================
model TaskStateTransition {
  id              String      @id @default(cuid())
  taskId          String
  fromStatus      TaskStatus?
  toStatus        TaskStatus
  triggeredBy     String? // User ID who triggered the change
  triggeredByType String? // 'CLIENT', 'RIDER', 'SYSTEM', 'ADMIN'
  reason          String?
  metadata        String? // JSON string for additional data
  latitude        Float?
  longitude       Float?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime    @default(now())
  task            Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([fromStatus])
  @@index([toStatus])
  @@index([createdAt])
}

// ============================================
// DISPATCH MATCH MODEL
// Tracks dispatch attempts and outcomes
// ============================================
model DispatchMatch {
  id                 String              @id @default(cuid())
  taskId             String
  riderId            String
  matchScore         Float
  distanceKm         Float?
  estimatedArrival   Int? // Seconds
  matchReason        String? // 'NEAREST', 'HIGHEST_RATED', 'MANUAL'
  status             DispatchMatchStatus @default(PENDING)
  expiresAt          DateTime
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  expiredAt          DateTime?
  cancelledAt        DateTime?
  rejectionReason    String?
  notificationSent   Boolean             @default(false)
  notificationSentAt DateTime?
  retryCount         Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  rider              Rider               @relation(fields: [riderId], references: [id])
  task               Task                @relation(fields: [taskId], references: [id])

  @@index([taskId])
  @@index([riderId])
  @@index([status])
  @@index([expiresAt])
}

// ============================================
// TRANSACTION MODEL
// Financial transaction ledger
// ============================================
model Transaction {
  id               String            @id @default(cuid())
  transactionRef   String            @unique
  userId           String?
  riderId          String?
  merchantId       String?
  taskId           String?
  orderId          String?
  type             TransactionType
  amount           Float
  currency         String            @default("UGX")
  balanceBefore    Float
  balanceAfter     Float
  status           TransactionStatus @default(COMPLETED)
  paymentMethod    String?
  paymentReference String?
  description      String?
  metadata         String? // JSON for additional data
  processedAt      DateTime          @default(now())
  reversedAt       DateTime?
  reversalReason   String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  rider            Rider?            @relation(fields: [riderId], references: [id])
  task             Task?             @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([riderId])
  @@index([merchantId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// SETTLEMENT MODEL
// Payout settlements for riders and merchants
// ============================================
model Settlement {
  id                 String                  @id @default(cuid())
  settlementRef      String                  @unique
  recipientType      SettlementRecipientType
  recipientId        String // Rider ID or Merchant ID
  periodStart        DateTime
  periodEnd          DateTime
  taskCount          Int                     @default(0)
  orderCount         Int                     @default(0)
  grossAmount        Float
  platformCommission Float
  adjustments        Float                   @default(0)
  netAmount          Float
  currency           String                  @default("UGX")
  status             SettlementStatus        @default(PENDING)
  paymentMethod      String?
  paymentReference   String?
  processedAt        DateTime?
  paidAt             DateTime?
  failedAt           DateTime?
  failureReason      String?
  processedBy        String? // Admin who processed
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([recipientType])
  @@index([recipientId])
  @@index([status])
  @@index([periodStart])
  @@index([createdAt])
}

// ============================================
// ADMIN PERMISSION MODEL
// Fine-grained RBAC permissions
// ============================================
model AdminPermission {
  id         String   @id @default(cuid())
  role       UserRole
  resource   String // 'riders', 'tasks', 'merchants', 'finance', etc.
  action     String // 'create', 'read', 'update', 'delete', 'approve', 'suspend'
  isAllowed  Boolean  @default(true)
  conditions String? // JSON for conditional permissions
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([role, resource, action])
  @@index([role])
  @@index([resource])
}

// ============================================
// DISPUTE MODEL
// Dispute handling for tasks and orders
// ============================================
model Dispute {
  id             String          @id @default(cuid())
  disputeNumber  String          @unique
  taskId         String?         @unique
  orderId        String?
  healthOrderId  String?
  clientId       String
  riderId        String?
  merchantId     String?
  disputeType    DisputeType
  category       String
  description    String
  status         DisputeStatus   @default(OPEN)
  priority       DisputePriority @default(MEDIUM)
  resolution     String?
  resolutionType String? // 'REFUND', 'PARTIAL_REFUND', 'CREDIT', 'NO_ACTION'
  refundAmount   Float?
  creditAmount   Float?
  openedAt       DateTime        @default(now())
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  resolvedBy     String?
  closedAt       DateTime?
  closedBy       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  task           Task?           @relation(fields: [taskId], references: [id])
  client         User            @relation(fields: [clientId], references: [id])

  @@index([taskId])
  @@index([orderId])
  @@index([clientId])
  @@index([riderId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// ============================================
// DOCUMENT EXPIRY MODEL
// Tracks document expiration dates
// ============================================
model DocumentExpiry {
  id                 String    @id @default(cuid())
  documentId         String    @unique
  documentType       String
  ownerId            String
  ownerType          String // 'RIDER', 'MERCHANT', 'PROVIDER'
  expiryDate         DateTime
  reminderSentAt     DateTime?
  firstWarningSentAt DateTime?
  finalWarningSentAt DateTime?
  isExpired          Boolean   @default(false)
  isActioned         Boolean   @default(false)
  actionedAt         DateTime?
  actionedBy         String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([ownerId])
  @@index([ownerType])
  @@index([expiryDate])
  @@index([isExpired])
}

// ============================================
// NOTIFICATION LOG MODEL
// Tracks notification delivery
// ============================================
model NotificationLog {
  id             String                     @id @default(cuid())
  userId         String
  notificationId String?
  type           NotificationChannel
  status         NotificationDeliveryStatus @default(PENDING)
  title          String
  message        String
  data           String? // JSON
  provider       String? // 'FCM', 'SMS', 'EMAIL'
  providerRef    String? // Provider message ID
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  retryCount     Int                        @default(0)
  createdAt      DateTime                   @default(now())
  user           User                       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// OFFLINE ACTION MODEL
// Offline action queue for sync
// ============================================
model OfflineAction {
  id             String              @id @default(cuid())
  userId         String
  actionType     String // 'CREATE_TASK', 'UPDATE_STATUS', 'CREATE_ORDER', etc.
  entityType     String // 'Task', 'Order', 'HealthOrder'
  entityId       String? // Local ID if created offline
  payload        String // JSON payload
  status         OfflineActionStatus @default(PENDING)
  syncedAt       DateTime?
  syncedEntityId String? // Server ID after sync
  conflictData   String? // JSON for conflict resolution
  resolvedAt     DateTime?
  retryCount     Int                 @default(0)
  deviceId       String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([userId])
  @@index([status])
  @@index([actionType])
  @@index([createdAt])
}

// ============================================
// TASK ANALYTICS MODEL
// Daily aggregated task metrics
// ============================================
model TaskAnalytics {
  id                String   @id @default(cuid())
  date              DateTime
  taskType          TaskType
  totalCreated      Int      @default(0)
  totalCompleted    Int      @default(0)
  totalCancelled    Int      @default(0)
  totalFailed       Int      @default(0)
  avgCompletionTime Int? // Seconds
  avgRating         Float?
  totalRevenue      Float    @default(0)
  totalCommission   Float    @default(0)
  avgDistance       Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([date, taskType])
  @@index([date])
  @@index([taskType])
}

// ============================================
// PLATFORM METRICS MODEL
// System-wide daily metrics
// ============================================
model PlatformMetrics {
  id                   String   @id @default(cuid())
  date                 DateTime @unique
  activeRiders         Int      @default(0)
  activeClients        Int      @default(0)
  totalTasksCompleted  Int      @default(0)
  totalRevenue         Float    @default(0)
  totalCommission      Float    @default(0)
  totalPayouts         Float    @default(0)
  avgResponseTime      Int? // Seconds
  avgDispatchTime      Int? // Seconds
  customerSatisfaction Float?
  newRegistrations     Int      @default(0)
  disputesOpened       Int      @default(0)
  disputesResolved     Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([date])
}

// ============================================
// WALLET MODEL
// Digital wallet for users, riders, merchants
// ============================================
model Wallet {
  id               String        @id @default(cuid())
  ownerId          String
  ownerType        WalletOwnerType
  balance          Float         @default(0)
  pendingBalance   Float         @default(0)
  currency         String        @default("UGX")
  status           WalletStatus  @default(ACTIVE)
  totalDeposited   Float         @default(0)
  totalWithdrawn   Float         @default(0)
  totalSpent       Float         @default(0)
  totalReceived    Float         @default(0)
  lastDepositAt    DateTime?
  lastWithdrawalAt DateTime?
  lastTransactionAt DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  transactions     WalletTransaction[]

  @@unique([ownerId, ownerType])
  @@index([ownerId])
  @@index([ownerType])
  @@index([status])
}

// ============================================
// WALLET TRANSACTION MODEL
// Tracks all wallet balance changes
// ============================================
model WalletTransaction {
  id                 String                  @id @default(cuid())
  walletId           String
  transactionType    WalletTransactionType
  amount             Float
  balanceBefore      Float
  balanceAfter       Float
  referenceId        String?
  referenceType      String?
  externalReference  String?
  externalProvider   String?
  description        String?
  status             WalletTransactionStatus @default(COMPLETED)
  metadata           String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  wallet             Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([transactionType])
  @@index([referenceId])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// CART MODEL
// Shopping cart for marketplace orders
// ============================================
model Cart {
  id             String    @id @default(cuid())
  userId         String    @unique
  merchantId     String?
  isActive       Boolean   @default(true)
  lastActivityAt DateTime  @default(now())
  abandonedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  items          CartItem[]

  @@index([userId])
  @@index([merchantId])
  @@index([isActive])
  @@index([abandonedAt])
}

// ============================================
// CART ITEM MODEL
// Individual items in a shopping cart
// ============================================
model CartItem {
  id            String   @id @default(cuid())
  cartId        String
  menuItemId    String
  productName   String
  quantity      Int      @default(1)
  unitPrice     Float
  totalPrice    Float
  specialNotes  String?
  priceSnapshot Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  cart          Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([menuItemId])
  @@index([isActive])
}

// ============================================
// PRODUCT VARIANT MODEL
// Variants for menu items (size, color, etc.)
// ============================================
model ProductVariant {
  id            String   @id @default(cuid())
  menuItemId    String
  variantName   String
  variantValue  String
  priceModifier Float    @default(0)
  stockQuantity Int?
  isAvailable   Boolean  @default(true)
  sku           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([isAvailable])
}

// ============================================
// INVENTORY RESERVATION MODEL
// Temporary stock reservations during checkout
// ============================================
model InventoryReservation {
  id          String                     @id @default(cuid())
  menuItemId  String
  variantId   String?
  orderId     String?
  taskId      String?
  quantity    Int
  status      InventoryReservationStatus @default(RESERVED)
  expiresAt   DateTime
  releasedAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  menuItem    MenuItem                   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
  @@index([orderId])
  @@index([status])
  @@index([expiresAt])
}

// ============================================
// RIDER METRICS MODEL
// Operational metrics for rider performance
// ============================================
model RiderMetrics {
  id                 String   @id @default(cuid())
  riderId            String   @unique
  acceptanceRate     Float    @default(0)
  cancellationRate   Float    @default(0)
  completionRate     Float    @default(0)
  averageRating      Float    @default(0)
  totalOnlineHours   Float    @default(0)
  totalTasksOffered  Int      @default(0)
  totalTasksAccepted Int      @default(0)
  totalTasksCompleted Int     @default(0)
  totalTasksCancelled Int     @default(0)
  lastCalculatedAt   DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([riderId])
  @@index([acceptanceRate])
  @@index([averageRating])
}

// ============================================
// MERCHANT DOCUMENT MODEL
// Document management for merchant verification
// ============================================
model MerchantDocument {
  id                String         @id @default(cuid())
  merchantId        String
  documentType      String
  documentName      String
  documentUrl       String
  documentSize      Int?
  status            DocumentStatus @default(PENDING)
  verifiedAt        DateTime?
  verifiedBy        String?
  rejectionReason   String?
  verificationNotes String?
  uploadedAt        DateTime       @default(now())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([merchantId])
  @@index([documentType])
  @@index([status])
}

// ============================================
// PAYMENT STATE TRANSITION MODEL
// Strict payment state machine audit trail
// ============================================
model PaymentStateTransition {
  id              String        @id @default(cuid())
  paymentId       String
  fromStatus      PaymentStatus?
  toStatus        PaymentStatus
  triggeredBy     String?
  triggeredByType String?
  reason          String?
  metadata        String?
  ipAddress       String?
  createdAt       DateTime      @default(now())

  @@index([paymentId])
  @@index([fromStatus])
  @@index([toStatus])
  @@index([createdAt])
}

