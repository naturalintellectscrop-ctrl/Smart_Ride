    "@tanstack/react-query": "^5.45.1",
    "expo": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "nativewind": "^2.0.11",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
